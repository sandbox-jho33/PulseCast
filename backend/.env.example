# PulseCast Backend Environment Variables

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Supabase Configuration (Required for persistent storage)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# If not set, falls back to in-memory storage (data lost on restart)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Preferred for server-side writes (storage + DB bypassing RLS):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Backward-compatible alias (optional):
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=podcast-audio

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LLM Provider Configuration
# Options: "ollama" (default, free/local), "openai", or "anthropic"
# This sets the server-side default. Users can override per-request via the UI (BYOK).
LLM_PROVIDER=ollama

# Ollama Configuration (Primary - Free/Local)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI Configuration (Cloud - requires API key)
# Used when LLM_PROVIDER=openai OR when user supplies an OpenAI key via UI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic Configuration (Cloud - requires API key)
# Used when LLM_PROVIDER=anthropic OR when user supplies an Anthropic key via UI
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# LLM Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# XTTS v2 TTS Service (Docker container for local TTS)
# Run: docker-compose up -d tts
# If backend runs on host: http://localhost:5002
# If backend runs in docker-compose: http://tts:5002
TTS_SERVICE_URL=http://localhost:5002

# ElevenLabs TTS API (alternative cloud TTS - paid)
# ELEVENLABS_API_KEY=your-elevenlabs-key

# AWS S3 (alternative to Supabase Storage for audio files)
# AWS_S3_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
