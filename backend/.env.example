# PulseCast Backend Environment Variables

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Supabase Configuration (Required for production persistent storage)

SUPABASE_URL=https://your-project.supabase.co

# Preferred for server-side writes (storage + DB bypassing RLS):
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

SUPABASE_STORAGE_BUCKET=podcast-audio

# =============================================================================
# AUTH + SECURITY
# =============================================================================

APP_ENV=development
FRONTEND_ORIGINS=http://localhost:5173
BACKEND_PUBLIC_URL=http://localhost:8000

# Clerk issuer from your Clerk dashboard, e.g. https://your-app.clerk.accounts.dev
CLERK_ISSUER=https://your-clerk-issuer
# Optional if you configure JWT audience in Clerk.
# CLERK_AUDIENCE=pulsecast

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=replace-with-fernet-key

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# Users provide OpenAI or Anthropic API keys in the app.
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# LLM Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# =============================================================================
# TTS
# =============================================================================

# Users provide ElevenLabs API keys in the app. Voice IDs are app configuration.
TTS_PROVIDER=elevenlabs
ELEVENLABS_LEO_VOICE_ID=your-leo-voice-id
ELEVENLABS_SARAH_VOICE_ID=your-sarah-voice-id
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
