# PulseCast Backend Environment Variables

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Supabase Configuration (Required for persistent storage)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# If not set, falls back to in-memory storage (data lost on restart)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_STORAGE_BUCKET=podcast-audio

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LLM Provider Configuration
# Options: "ollama" (default, free/local) or "openai" (cloud, paid)
LLM_PROVIDER=ollama

# Ollama Configuration (Primary - Free/Local)
OLLAMA_MODEL=llama3.2:3b
OLLAMA_BASE_URL=http://host.docker.internal:11434

# OpenAI Configuration (Fallback - Cloud/Paid)
# Required only if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# LLM Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# XTTS v2 TTS Service (Docker container for local TTS)
# Run: docker-compose up -d tts
TTS_SERVICE_URL=http://localhost:5002

# ElevenLabs TTS API (alternative cloud TTS - paid)
# ELEVENLABS_API_KEY=your-elevenlabs-key

# AWS S3 (alternative to Supabase Storage for audio files)
# AWS_S3_BUCKET=your-s3-bucket
# AWS_ACCESS_KEY_ID=your-aws-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret
# AWS_REGION=us-east-1
