# PulseCast Backend Environment Variables

# =============================================================================
# STORAGE CONFIGURATION
# =============================================================================

# Supabase Configuration (Required for persistent storage)
# If not set, falls back to in-memory storage (data lost on restart)

SUPABASE_URL=https://mtcxbvkqzmckdoqpdksd.supabase.co

# Preferred for server-side writes (storage + DB bypassing RLS):
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...

SUPABASE_STORAGE_BUCKET=podcast-audio

# =============================================================================
# LLM CONFIGURATION
# =============================================================================

# LLM Provider Configuration
# Options: "ollama" (default, free/local), "openai", or "anthropic"
# API keys for cloud providers live here only. Frontend never sees them.
LLM_PROVIDER=ollama

# Ollama Configuration (Primary - Free/Local)
OLLAMA_MODEL=llama3.2:1b
OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Configuration (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Configuration (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-4-7-opus

# LLM Temperature (0.0 - 1.0)
LLM_TEMPERATURE=0.7

# =============================================================================
# OPTIONAL SERVICES
# =============================================================================

# XTTS v2 TTS Service (Docker container for local TTS)
# Run: docker-compose up -d tts
# If backend runs on host: http://localhost:5002
# If backend runs in docker-compose: http://tts:5002
TTS_SERVICE_URL=http://localhost:5002

# ElevenLabs TTS API (alternative cloud TTS - paid)
# ELEVENLABS_API_KEY=your-elevenlabs-key
